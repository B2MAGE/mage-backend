root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cmd]
end_of_line = crlf

[*.java]
indent_style = tab
tab_width = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml,properties,sql}]
indent_style = space
indent_size = 2
