# Local Docker Compose convenience file.
# Copy this to .env for local development.

SPRING_APPLICATION_NAME=mage-backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
MAGE_AUTH_GOOGLE_CLIENT_IDS=replace-with-your-google-client-id.apps.googleusercontent.com

POSTGRES_DB=mage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mage
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me
