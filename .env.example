# Local Docker Compose convenience file.
# Copy this to .env for local development.

SPRING_APPLICATION_NAME=mage-backend
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=default
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
MAGE_AUTH_GOOGLE_CLIENT_IDS=replace-with-your-google-client-id.apps.googleusercontent.com

POSTGRES_DB=mage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mage
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# Object-storage backed preset thumbnail uploads
# Provider options:
# - aws-s3: AWS S3 with IAM role or standard AWS credentials
# - minio: self-hosted S3-compatible storage such as MinIO
MAGE_THUMBNAIL_PROVIDER=aws-s3
AWS_REGION=us-east-1
MAGE_THUMBNAIL_REGION=
MAGE_THUMBNAIL_BUCKET=replace-with-your-thumbnail-bucket
MAGE_THUMBNAIL_KEY_PREFIX=presets
MAGE_THUMBNAIL_ENDPOINT=
MAGE_THUMBNAIL_PRESIGN_ENDPOINT=
MAGE_THUMBNAIL_ACCESS_KEY_ID=
MAGE_THUMBNAIL_SECRET_ACCESS_KEY=
MAGE_THUMBNAIL_PATH_STYLE_ACCESS=
MAGE_THUMBNAIL_PUBLIC_BASE_URL=https://replace-with-your-thumbnail-base-url
MAGE_THUMBNAIL_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif
MAGE_THUMBNAIL_MAX_BYTES=5242880
MAGE_THUMBNAIL_PRESIGN_DURATION=PT10M

# Optional MinIO-only defaults if you use docker-compose.minio.yml locally.
MAGE_THUMBNAIL_MINIO_REGION=us-east-1
MAGE_THUMBNAIL_MINIO_BUCKET=mage-local-thumbnails
MAGE_THUMBNAIL_MINIO_ENDPOINT=http://minio:9000
MAGE_THUMBNAIL_MINIO_PRESIGN_ENDPOINT=http://localhost:9000
MAGE_THUMBNAIL_MINIO_PUBLIC_BASE_URL=http://localhost:9000/mage-local-thumbnails
MAGE_THUMBNAIL_MINIO_ACCESS_KEY_ID=minioadmin
MAGE_THUMBNAIL_MINIO_SECRET_ACCESS_KEY=minioadmin
MAGE_THUMBNAIL_MINIO_ROOT_USER=minioadmin
MAGE_THUMBNAIL_MINIO_ROOT_PASSWORD=minioadmin

# Optional AWS credentials for Dockerized backend runs outside EC2 when using aws-s3.
# Leave these unset in production when the backend uses an EC2 IAM role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
